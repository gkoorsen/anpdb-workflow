# OS/editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Python caches and local environments
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/
.env
.env.*

# R/session artifacts
.Rhistory
.RData

# Node dependencies
node_modules/
ppt/node_modules/

# Large external inputs and derived indexes.
# Keep scripts and metadata in Git; stage source datasets elsewhere.
data/*
!data/README.md
!data/.gitkeep
!data/md_inputs/
data/md_inputs/*
!data/md_inputs/amber_systems/
!data/md_inputs/amber_systems/.gitkeep
!data/md_inputs/amber_systems/*.prmtop
!data/md_inputs/amber_systems/*.parm7
!data/md_inputs/amber_systems/*.inpcrd
!data/md_inputs/amber_systems/*.rst7

# Generated analysis outputs.
# Curated summary tables/figures should be copied into a tracked docs/ or results/ folder later.
output/*
!output/README.md
!output/.gitkeep

# Long MD/GROMACS/OpenMM production artifacts
runs/
md_runs/
*.dcd
*.xtc
*.trr
*.nc
*.h5
*.hdf5
*.chk
*.cpt
*.edr
*.tpr
*.xvg
*.log

# Presentation/editor lock files
~$*
